# Backend service URLs. Phase 1 ignores these (mock clients) but they are
# read at config load so the server fails fast in Phase 2 if missing.
AUTO_SENTINEL_URL=http://localhost:8001
DEVDOCS_RAG_URL=http://localhost:8002

# Phase 1: leave as "mock" to use in-memory canned responses.
# Phase 2: set to "http" to enable real HTTP calls.
DEVCONTEXT_BACKEND_MODE=mock
